# SafeLoop 환경 변수 예시 — 실제 사용 시 .env 로 복사 후 키만 교체
#
# 사용 흐름:
#   cp .env.example .env
#   nano .env       # ANTHROPIC_API_KEY 값 입력
#   python -m streamlit run app.py
#
# 또는 (권장): 암호화본 unlock
#   python setup.py unlock      # → .env 자동 생성
#
# Streamlit Cloud 배포 시:
#   .env 사용 안 함. Settings → Secrets 에 동일 키 입력.

# === 필수: AI 비전 공급자 (둘 중 하나만 있어도 동작) ===

ANTHROPIC_API_KEY=sk-ant-api03-여기에-실제-키-붙여넣기
# 발급: https://console.anthropic.com/settings/keys

# OPENAI_API_KEY=sk-여기에-실제-키-붙여넣기
# 발급: https://platform.openai.com/api-keys

# === 선택: 자동 공급자 우선 (없으면 사용 가능한 첫 번째 자동 선택) ===
# SAFELOOP_PROVIDER=anthropic   # 또는 openai

# === 선택: 프록시 환경 (학교/사내망에서 필요) ===
# HTTPS_PROXY=http://proxy.example.com:8080
